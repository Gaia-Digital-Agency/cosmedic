DATABASE_URI=postgres://cosmedic:REPLACE_ME@127.0.0.1:5432/cosmedic
PAYLOAD_SECRET=REPLACE_ME
PORT=4007
FRONTEND_URL=http://localhost:3007

# Bootstrap super-admin (Phase 1 convenience — rotate in Phase 12).
PAYLOAD_SEED_ADMIN_EMAIL=super_admin@email.com
PAYLOAD_SEED_ADMIN_PASSWORD=REPLACE_ME

# Web revalidate target — POST'd to by Payload afterChange hooks (Phase 6c).
WEB_URL=http://127.0.0.1:3007

# ── Phase 7: enquiry emails ──────────────────────────────────────────────
# If all SMTP_* are unset, the JSON transport is used (emails are logged to
# stdout, never delivered) — useful for dev and pre-launch smoke tests.
# Pick a provider (Postmark / SES / clinic relay) and fill these in.
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=<server-token>
# SMTP_PASS=<same-as-user-for-postmark>

# From-address used on all outbound mail.
MAIL_FROM="Cosmedic CMS <no-reply@cosmedic.gaiada.online>"

# Where clinic-notify emails are delivered.
MAIL_CLINIC_TO=cosmedic@bimcbali.com
